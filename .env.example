# NEST environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Comma-separated list of email addresses that are granted the admin role
# when they sign up or log in (bootstrap mechanism — the persistent
# role:"admin" field on the account is what authorization checks).
# Example: "founder@example.com,ops@example.com"
ADMIN_EMAILS=""

# Port for the local / self-hosted server. Defaults to 3000.
# PORT=3000

# --- Stripe (NEST Premium, €20/month) -----------------------------------
# Payments stay safely disabled until ALL of these are set; endpoints then
# activate automatically. See docs/STRIPE.md for the full setup guide.

# Secret API key (sk_test_… or sk_live_…). Server only — never expose.
# STRIPE_SECRET_KEY=

# ID of the recurring monthly Price (€20.00) created in the Stripe
# dashboard, e.g. price_123…
# STRIPE_PREMIUM_PRICE_ID=

# Signing secret (whsec_…) of the webhook endpoint pointing to
# /api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=

# Public base URL used for Stripe success/cancel redirects
# (e.g. https://nest.example.com). Falls back to the Vercel deployment URL
# or http://localhost:PORT.
# APP_BASE_URL=

# Optional bootstrap for ephemeral preview deployments: base64-encoded JSON
# (partial database: typically one admin user + profile) applied when the
# database file does not exist, e.g. after a Vercel cold start. Generate it
# with scripts/make-db-seed.mjs and pipe it straight into
# `vercel env add DB_SEED production` — passwords must already be
# scrypt-hashed (the script refuses plain text) and sessions are never
# seeded.
# DB_SEED=

# --- Frontend build-time variables ---------------------------------------

# API origin for packaged builds (e.g. the Capacitor iOS shell) where the
# app is not served by the API host. Leave unset for the normal web build
# (same-origin requests). Example: https://api.nest.example.com
# VITE_API_BASE_URL=

# --- Optional path overrides (defaults are fine in almost all cases) ----

# Absolute path to the JSON database file.
# Defaults to ./db.json locally, /tmp/db.json on Vercel (ephemeral).
# DB_PATH=

# Absolute path to the uploaded-images directory.
# Defaults to ./uploads locally, /tmp/uploads on Vercel (ephemeral).
# UPLOAD_DIR=
