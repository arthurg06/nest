# Dependencies
node_modules/

# Build output
dist/
build/
coverage/

# Local database (contains real user data — never commit)
db.json
db.json.tmp

# User-uploaded content (never commit)
uploads/*
!uploads/.gitkeep

# Supplied personal source assets (applied locally via scripts/, never committed)
images/

# Personal seed assets deployed to Vercel but never committed
# (uploaded by CLI deploys because .vercelignore does not list them)
public/seed/

# Environment variables (secrets)
.env
.env.*
!.env.example

# Vercel
.vercel/

# Logs & OS files
*.log
.DS_Store
.vercel

# Tool-installed agent helper files (Neon marketplace CLI)
.agents/
.claude/
skills-lock.json
